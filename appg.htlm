<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BETANGAR — Control de Flota v9.1 (Optimizado AI)</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#08111f;--bg2:#0c1a2e;--bg3:#0f2040;
  --card:#0d1e3a;--card2:#112347;
  --border:#1e3a5f;--border2:#2a5080;
  --green:#a3e635;--green2:#84cc16;--green3:#65a30d;
  --lime:#a3e635;--teal:#14b8a6;
  --yellow:#fbbf24;--orange:#fb923c;
  --red:#f87171;--blue:#38bdf8;--purple:#a78bfa;
  --text:#e8f4ff;--text2:#7eb8d4;--text3:#2d5c7a;
  --f:'Outfit',sans-serif;--m:'JetBrains Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--f);display:flex;flex-direction:column}
.topnav{background:linear-gradient(135deg,#0c1a2e,#0f2040);border-bottom:1px solid var(--border);padding:0 10px;display:flex;align-items:center;flex-shrink:0;height:48px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.4)}
.nav-logo{display:flex;align-items:center;padding-right:10px;border-right:1px solid var(--border);flex-shrink:0}
.nav-right{display:flex;align-items:center;gap:6px;flex-shrink:0}
.btn-icon{background:var(--card2);border:1px solid var(--border2);border-radius:8px;font-size:16px;width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;color:var(--text)}
.btn-icon:hover{border-color:var(--green);background:rgba(163,230,53,.15);color:var(--green)}
.menu-item{display:flex;align-items:center;gap:8px;padding:9px 18px;font-size:13px;font-weight:600;color:var(--text2);cursor:pointer;border-left:3px solid transparent;transition:all .12s}
.menu-item:hover{background:rgba(45,255,122,.06);color:var(--text)}
.menu-item.active{color:var(--lime);border-left-color:var(--lime);background:rgba(163,230,53,.08)}
.menu-group{font-size:9px;color:var(--text3);letter-spacing:2px;text-transform:uppercase;padding:8px 18px 2px;font-weight:700}
.app-body{flex:1;overflow:hidden;display:flex;flex-direction:column}
.page{display:none;flex:1;overflow-y:auto;padding:14px 18px}
.page.active{display:block}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:var(--f);transition:all .15s}
.btn-g{background:var(--green);color:#000}.btn-g:hover{background:var(--green2)}
.btn-s{background:var(--card2);color:var(--text);border:1px solid var(--border)}.btn-s:hover{border-color:var(--green2);color:var(--green2)}
.btn-y{background:rgba(251,191,36,.15);color:var(--yellow);border:1px solid rgba(251,191,36,.3)}
.btn-r{background:rgba(248,113,113,.12);color:var(--red);border:1px solid rgba(248,113,113,.25)}
.btn-b{background:rgba(56,189,248,.12);color:var(--blue);border:1px solid rgba(56,189,248,.25)}
.btn-p{background:rgba(167,139,250,.12);color:var(--purple);border:1px solid rgba(167,139,250,.25)}
.btn-sm{padding:4px 10px;font-size:11px}.btn-xs{padding:3px 8px;font-size:10px;border-radius:5px}
.card{background:linear-gradient(145deg,var(--card),var(--card2));border:1px solid var(--border);border-radius:10px;padding:14px;box-shadow:0 4px 12px rgba(0,0,0,.2)}
.card-sm{padding:8px 12px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.stat{background:linear-gradient(145deg,var(--card),var(--card2));border:1px solid var(--border);border-radius:10px;padding:12px 14px;border-top:3px solid var(--lime);box-shadow:0 4px 12px rgba(0,0,0,.2)}
.stat.y{border-top-color:var(--yellow)}.stat.r{border-top-color:var(--red)}.stat.b{border-top-color:var(--blue)}.stat.t{border-top-color:var(--teal)}.stat.p{border-top-color:var(--purple)}
.stat-lbl{font-size:9px;color:#7eb8d4;letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:4px}
.stat-val{font-family:var(--m);font-size:20px;font-weight:700;color:#fff;line-height:1}
.stat-sub{font-size:10px;color:#7eb8d4;margin-top:3px}
.fg{margin-bottom:10px}
.fg label{display:block;font-size:10px;color:var(--text2);letter-spacing:.4px;margin-bottom:4px;font-weight:700}
.fc{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--text);font-family:var(--f);font-size:13px;padding:7px 10px;border-radius:7px;transition:border-color .15s}
.fc:focus{outline:none;border-color:var(--green3)}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.fr4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.tw{overflow-x:auto;border-radius:9px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse}
th{background:var(--bg3);padding:7px 10px;text-align:left;font-size:9px;color:#a0c8e0;letter-spacing:1px;text-transform:uppercase;font-weight:700;white-space:nowrap}
td{padding:6px 10px;border-top:1px solid var(--border);font-size:12px;white-space:nowrap;color:var(--text)}
tr:hover td{background:rgba(45,255,122,.02)}
.badge{display:inline-block;padding:1px 7px;border-radius:20px;font-size:9px;font-weight:700;font-family:var(--m)}
.bg{background:rgba(45,255,122,.2);color:#a3e635}.by{background:rgba(251,191,36,.2);color:#fbbf24}
.br{background:rgba(248,113,113,.2);color:#f87171}.bb{background:rgba(96,165,250,.2);color:#60a5fa}
.bt{background:rgba(20,184,166,.2);color:#14b8a6}.bp{background:rgba(167,139,250,.2);color:#a78bfa}
.ctr{display:flex;align-items:center;gap:8px}
.cb{width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.cb:hover{border-color:var(--green);color:var(--green)}
.cv{font-family:var(--m);font-size:20px;font-weight:700;min-width:28px;text-align:center;color:var(--green)}
.pbar{height:5px;background:var(--border);border-radius:3px;overflow:hidden;margin-top:5px}
.pfill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--green),var(--teal));transition:width .4s}
.alert-ok{background:rgba(45,255,122,.08);border:1px solid rgba(45,255,122,.25);color:var(--green);padding:8px 12px;border-radius:7px;font-size:12px;margin-bottom:10px;display:none}
.alert-w{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.25);color:var(--yellow);padding:8px 12px;border-radius:7px;font-size:12px;margin-bottom:6px}
.alert-r{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);color:var(--red);padding:8px 12px;border-radius:7px;font-size:12px;margin-bottom:6px}
.alert-b{background:rgba(56,189,248,.08);border:1px solid rgba(56,189,248,.25);color:var(--blue);padding:8px 12px;border-radius:7px;font-size:12px;margin-bottom:6px}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.st{font-size:13px;font-weight:800;color:#fff}
.sep{height:1px;background:var(--border);margin:12px 0}
.cbox{background:linear-gradient(145deg,var(--card),var(--card2));border:1px solid var(--border);border-radius:10px;padding:14px;box-shadow:0 4px 12px rgba(0,0,0,.2)}
.ctitle{font-size:12px;font-weight:700;color:var(--text);margin-bottom:10px}
.moverlay{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:999;display:none;align-items:center;justify-content:center}
.moverlay.open{display:flex}
.mbox{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:22px;width:100%;max-width:800px;max-height:92vh;overflow-y:auto}
.mtitle{font-size:15px;font-weight:800;color:#fff;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center}
.mclose{cursor:pointer;color:var(--text2);background:none;border:none;font-size:18px;color:var(--text2)}
.switch-row{display:flex;gap:4px;margin-bottom:10px;flex-wrap:wrap}
.sw{padding:5px 12px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border);color:var(--text2);background:var(--bg3)}
.sw.on{background:rgba(45,255,122,.12);border-color:var(--green2);color:var(--green)}
.venc-ok{background:rgba(163,230,53,.15);color:var(--green);border:1px solid rgba(163,230,53,.3);padding:2px 8px;border-radius:12px;font-size:9px;font-weight:700}
.venc-prox{background:rgba(251,191,36,.15);color:var(--yellow);border:1px solid rgba(251,191,36,.3);padding:2px 8px;border-radius:12px;font-size:9px;font-weight:700}
.venc-venc{background:rgba(248,113,113,.15);color:var(--red);border:1px solid rgba(248,113,113,.3);padding:2px 8px;border-radius:12px;font-size:9px;font-weight:700}
.venc-nd{background:rgba(45,92,122,.2);color:var(--text3);border:1px solid var(--border);padding:2px 8px;border-radius:12px;font-size:9px;font-weight:700}
.bnc-card{background:linear-gradient(135deg,#050f1e,#091828);border:1px solid #1e3a6e;border-radius:12px;padding:16px;position:relative;overflow:hidden}
.bnc-card::after{content:'BNC';position:absolute;right:12px;top:10px;font-size:9px;font-weight:900;color:rgba(56,189,248,.25);letter-spacing:3px}
.demo-banner{background:rgba(251,191,36,.1);border-bottom:1px solid rgba(251,191,36,.3);padding:4px 16px;font-size:10px;color:var(--yellow);font-weight:700;text-align:center;display:none}
.login-overlay{position:fixed;inset:0;background:linear-gradient(135deg,#06101e,#0a1628,#0d2040);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;padding:20px}
.login-box{background:linear-gradient(145deg,#0d1e3a,#0f2040);border:1px solid var(--border2);border-radius:16px;padding:32px 28px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.login-btn{width:100%;background:linear-gradient(135deg,#a3e635,#84cc16);color:#000;border:none;padding:13px;border-radius:8px;font-size:14px;font-weight:800;cursor:pointer;font-family:var(--f);margin-top:8px;transition:all .15s;box-shadow:0 4px 15px rgba(163,230,53,.3)}
.login-btn:hover{background:linear-gradient(135deg,#bef264,#a3e635)}
.login-error{background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);color:var(--red);padding:8px 12px;border-radius:7px;font-size:12px;margin-top:10px;display:none;text-align:center}
.role-badge{display:inline-block;padding:2px 10px;border-radius:20px;font-size:10px;font-weight:700;font-family:var(--m)}
.role-admin{background:rgba(45,255,122,.15);color:var(--green)}
.role-operador{background:rgba(251,191,36,.15);color:var(--yellow)}
.role-rrhh{background:rgba(167,139,250,.15);color:var(--purple)}
.role-visualizador{background:rgba(96,165,250,.15);color:var(--blue)}
.tank-viz{height:80px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;overflow:hidden;position:relative;margin:8px 0}
.tank-fill{position:absolute;bottom:0;left:0;right:0;transition:height .5s;border-radius:0 0 7px 7px}
.tank-lbl{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--m);font-size:16px;font-weight:700;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,.5)}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
@media print{@page{size:letter;margin:1.5cm}body{overflow:visible}.topnav,.btn,.moverlay,.demo-banner{display:none!important}.page{display:block!important;padding:0;overflow:visible}}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script>
(function(){
  var cdns=[
    'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js',
    'https://unpkg.com/@supabase/supabase-js@2/dist/umd/supabase.js'
  ];
  var idx=0;
  function load(){
    var s=document.createElement('script');
    s.src=cdns[idx];
    s.onload=function(){console.log('Supabase CDN OK:'+cdns[idx]);};
    s.onerror=function(){
      idx++;
      if(idx<cdns.length){console.warn('CDN fallo, intentando siguiente...');load();}
      else{console.error('Todos los CDNs de Supabase fallaron');}
    };
    document.head.appendChild(s);
  }
  load();
})();
</script>
</head>
<body>
<div id="db-status-banner" style="display:none;position:fixed;top:8px;left:50%;transform:translateX(-50%);background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);color:#fff;padding:8px 20px;border-radius:8px;z-index:9999;font-size:12px;text-align:center;min-width:300px"></div>
<div class="demo-banner" id="demo-banner">⚠ MODO DEMO — Los cambios no se guardan</div>

<div class="login-overlay" id="login-overlay">
  <div class="login-box">
    <div style="text-align:center;margin-bottom:20px"><img id="login-logo-img" src="" alt="Betangar" style="height:65px;width:auto"></div>
    <div style="text-align:center;font-size:17px;font-weight:800;color:#fff;margin-bottom:3px">Control de Flota</div>
    <div style="text-align:center;font-size:11px;color:var(--text3);margin-bottom:22px">Inversiones Betangar C.A. · v9.1</div>
    <div class="fg"><label>USUARIO</label><input type="text" id="login-user" class="fc" placeholder="usuario" autocomplete="username" onkeydown="if(event.key==='Enter')document.getElementById('login-pass').focus()"></div>
    <div class="fg"><label>CONTRASENA</label><input type="password" id="login-pass" class="fc" placeholder="..." autocomplete="current-password" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="login-btn" onclick="doLogin()">Ingresar al Sistema</button>
    <div class="login-error" id="login-error">Usuario o contrasena incorrectos</div>
    <div style="text-align:center;font-size:9px;color:var(--text3);margin-top:18px">Inversiones Betangar CA · J-29566107-0 · v9.1</div>
  </div>
</div>

<nav class="topnav">
  <div class="nav-logo"><img id="nav-logo-img" src="" alt="BG" onerror="this.style.display='none'" style="height:28px;width:auto"></div>
  <div style="flex:1;display:flex;align-items:center;padding-left:10px">
    <span id="nav-active-label" style="font-size:13px;font-weight:700;color:var(--green)">Dashboard</span>
  </div>
  <div class="nav-right">
    <div id="bnc-nav-saldo" style="display:none;font-family:var(--m);font-size:11px;color:var(--blue);background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.2);border-radius:6px;padding:3px 8px;cursor:pointer" onclick="sp('banco')">BNC: --</div>
    <div id="nav-user-info" style="display:none;flex-direction:column;align-items:flex-end;gap:1px;margin-right:4px"></div>
    <button class="btn-icon" onclick="imprimirPagina()" title="Imprimir" style="color:#60a5fa;border-color:#2563eb">&#128424;</button>
    <button class="btn-icon" onclick="exportExcelCompleto()" title="Excel" style="color:#34d399;border-color:#059669">&#11015;</button>
    <button class="btn-icon" onclick="toggleMenu()" style="font-size:20px;border-color:var(--green);background:rgba(163,230,53,.12);color:var(--green)">&#9776;</button>
  </div>
</nav>

<div id="nav-menu" style="display:none;position:fixed;top:48px;left:0;right:0;bottom:0;z-index:998;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)" onclick="closeMenu()">
  <div onclick="event.stopPropagation()" style="background:linear-gradient(180deg,#0c1a2e,#08111f);border-right:1px solid var(--border2);padding:6px 0;box-shadow:0 8px 32px rgba(0,0,0,.6);max-height:100vh;overflow-y:auto;width:250px">
    <div class="menu-group">PRINCIPAL</div>
    <div class="menu-item active" onclick="sp('dashboard')" id="mi-dashboard">📊 Dashboard</div>
    <div class="menu-item" onclick="sp('planilla')" id="mi-planilla">📋 Registro Diario</div>
    <div class="menu-item" onclick="sp('historico')" id="mi-historico">📁 Historico</div>
    <div class="menu-item" onclick="sp('reporte')" id="mi-reporte">📄 Reporte Alcaldia</div>
    <div class="menu-group">FINANCIERO</div>
    <div class="menu-item" onclick="sp('abonos')" id="mi-abonos">💰 Abonos / Cobros</div>
    <div class="menu-item" onclick="sp('banco')" id="mi-banco">🏦 Banco BNC</div>
    <div class="menu-item" onclick="sp('proveedores')" id="mi-proveedores">🤝 Cuentas por Pagar</div>
    <div class="menu-item" onclick="sp('financiero')" id="mi-financiero">📈 Financiero</div>
    <div class="menu-group">OPERACIONES</div>
    <div class="menu-item" onclick="sp('nomina')" id="mi-nomina">👥 Nomina</div>
    <div class="menu-item" onclick="sp('asistencia')" id="mi-asistencia">✅ Asistencia</div>
    <div class="menu-item" onclick="sp('combustible')" id="mi-combustible">⛽ Combustible</div>
    <div class="menu-item" onclick="sp('km')" id="mi-km">🔧 Km / Servicio</div>
    <div class="menu-item" onclick="sp('documentos')" id="mi-documentos">📑 Documentos</div>
    <div class="menu-item" onclick="sp('inventario')" id="mi-inventario">📦 Inventario</div>
    <div class="menu-item" onclick="sp('llantas')" id="mi-llantas">🔄 Llantas</div>
    <div class="menu-item" onclick="sp('metas')" id="mi-metas">🎯 Metas</div>
    <div class="menu-group">RRHH</div>
    <div class="menu-item" onclick="sp('empleados')" id="mi-empleados">👤 Empleados</div>
    <div class="menu-item" onclick="sp('prestamos')" id="mi-prestamos">💳 Prestamos</div>
    <div class="menu-item" onclick="sp('multas')" id="mi-multas">⚖️ Multas</div>
    <div class="menu-group">ANALISIS</div>
    <div class="menu-item" onclick="sp('stats')" id="mi-stats">📉 Estadisticas</div>
    <div class="menu-item" onclick="sp('ranking')" id="mi-ranking">🏆 Ranking</div>
    <div class="menu-group">SISTEMA</div>
    <div class="menu-item" onclick="sp('contratos')" id="mi-contratos">📋 Contratos</div>
    <div class="menu-item" onclick="sp('usuarios')" id="mi-usuarios">🔐 Usuarios</div>
    <div class="menu-item" onclick="sp('auditoria')" id="mi-auditoria">🔍 Auditoria</div>
    <div class="menu-item" onclick="sp('config')" id="mi-config">⚙️ Configuracion</div>
    <div class="menu-item" onclick="sp('galeria')" id="mi-galeria">🏗️ Galeria</div>
    <div style="height:1px;background:var(--border);margin:6px 0"></div>
    <div class="menu-item" onclick="cerrarSesion()" style="color:var(--red)">🚪 Cerrar Sesion</div>
  </div>
</div>

<div class="app-body">
<div id="p-dashboard" class="page active">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding:10px 14px;background:linear-gradient(135deg,var(--card),var(--card2));border:1px solid var(--border);border-radius:10px">
    <img id="dash-logo" src="" alt="Betangar" style="height:36px;width:auto;opacity:.9">
    <div style="text-align:center"><div style="font-size:13px;font-weight:800;color:var(--green)">Control de Flota v9.1</div><div style="font-family:var(--m);font-size:10px;color:var(--text3)" id="fecha-top"></div></div>
    <div style="text-align:right;font-size:9px;color:var(--text3)">Sistema v9.1<br>Inversiones Betangar CA</div>
  </div>
  <div id="tasas-widget" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:7px 12px;margin-bottom:10px"><div style="font-size:10px;color:var(--text3)">Cargando tasas...</div></div>
  <div id="dash-alertas" style="margin-bottom:10px"></div>
  <div class="g5" style="margin-bottom:10px">
    <div class="stat"><div class="stat-lbl">Total Viajes</div><div class="stat-val" id="s-viajes">-</div><div class="stat-sub" id="s-viajes-sub">-</div></div>
    <div class="stat y"><div class="stat-lbl">Ejecutado</div><div class="stat-val" style="font-size:16px;color:var(--yellow)" id="s-ejec">-</div><div class="stat-sub" id="s-ejec-sub">@ $288/viaje</div></div>
    <div class="stat" style="border-top-color:var(--green2)"><div class="stat-lbl">Cobrado</div><div class="stat-val" style="font-size:16px;color:var(--green2)" id="s-cobrado">-</div><div class="stat-sub" id="s-cobrado-sub">-</div></div>
    <div class="stat r"><div class="stat-lbl">Por Cobrar</div><div class="stat-val" style="font-size:16px;color:var(--red)" id="s-porcobrar">-</div><div class="pbar"><div class="pfill" id="s-pbar" style="width:0%"></div></div></div>
    <div class="stat b"><div class="stat-lbl">Saldo BNC</div><div class="stat-val" style="font-size:15px;color:var(--blue)" id="s-saldo-bnc">--</div><div class="stat-sub" id="s-saldo-sub"><span onclick="sp('banco')" style="cursor:pointer;color:var(--blue)">Ver banco</span></div></div>
  </div>
  <div class="g2" style="margin-bottom:10px">
    <div class="cbox"><div class="ctitle">Viajes por Semana</div><div id="c-sem-svg"></div></div>
    <div class="cbox"><div class="ctitle">Viajes por Camion</div><div id="c-cam-svg"></div></div>
  </div>
  <div class="g2" style="margin-bottom:10px">
    <div class="cbox"><div class="ctitle">Estado de Cobros</div><div id="c-cob-svg"></div></div>
    <div class="card"><div class="sh"><div class="st">Ultimas Planillas</div></div><div id="ult-plan"></div></div>
  </div>
  <div id="dash-financiero" style="margin-bottom:10px"></div>
  <div class="g2" style="margin-bottom:10px">
    <div class="card"><div class="sh"><div class="st">🚛 Estado de Flota</div><div style="font-size:10px;color:var(--text3)" id="flota-resumen"></div></div><div id="flota-status"></div></div>
    <div class="card"><div class="sh"><div class="st">🏆 Top 5 Choferes</div></div><div id="dash-ranking"></div></div>
  </div>
  <div class="g2">
    <div class="card"><div class="sh"><div class="st">🎯 Metas Semanales</div><button class="btn btn-s btn-xs" onclick="sp('metas')">Ver todo</button></div><div id="dash-metas"></div></div>
    <div class="card"><div class="sh"><div class="st">⚠️ Proximos Vencimientos</div><button class="btn btn-s btn-xs" onclick="sp('documentos')">Ver todo</button></div><div id="dash-venc"></div></div>
