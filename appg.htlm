    <div class="sw" id="sw-bnc-mov" onclick="switchBNCTab('mov')">Movimientos</div>
    <div class="sw" id="sw-bnc-conc" onclick="switchBNCTab('conc')">Conciliacion</div>
    <div class="sw" id="sw-bnc-pend" onclick="switchBNCTab('pend')">Pagos Pendientes</div>
    <div class="sw" id="sw-bnc-cfg" onclick="switchBNCTab('cfg')">Config API</div>
  </div>
  <div id="tab-bnc-dash">
    <div class="g3" style="margin-bottom:14px">
      <div class="bnc-card"><div style="font-size:9px;color:var(--blue);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">Saldo Disponible</div><div style="font-family:var(--m);font-size:26px;font-weight:900;color:var(--blue)" id="bnc-saldo-main">Bs --</div><div style="font-size:10px;color:var(--text2);margin-top:4px" id="bnc-saldo-usd">USD --</div><div style="font-size:9px;color:var(--text3);margin-top:6px" id="bnc-saldo-fecha">Sin conexion</div></div>
      <div class="bnc-card"><div style="font-size:9px;color:var(--teal);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">Entradas del Dia</div><div style="font-family:var(--m);font-size:22px;font-weight:900;color:var(--teal)" id="bnc-entr-hoy">Bs --</div><div style="font-size:10px;color:var(--text2);margin-top:4px" id="bnc-entr-count">-- transferencias</div></div>
      <div class="bnc-card"><div style="font-size:9px;color:var(--yellow);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">Pagos por Autorizar</div><div style="font-family:var(--m);font-size:22px;font-weight:900;color:var(--yellow)" id="bnc-por-aut">0</div><div style="font-size:10px;color:var(--text2);margin-top:4px">Pendientes en BNCNET</div></div>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
      <button class="btn btn-b" onclick="consultarSaldoBNC()">🔄 Actualizar Saldo</button>
      <button class="btn btn-g" onclick="conciliarAutomatico()">⚡ Conciliar Automatico</button>
      <button class="btn btn-p" onclick="registrarMovManual()">+ Registrar Movimiento</button>
    </div>
    <div class="card"><div class="st" style="margin-bottom:10px">Ultimos Movimientos</div><div id="bnc-mov-recent"><div style="text-align:center;color:var(--text3);padding:20px;font-size:12px">Configura la API BNC o registra movimientos manualmente</div></div></div>
  </div>
  <div id="tab-bnc-mov" style="display:none">
    <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;align-items:flex-end">
      <div class="fg" style="margin:0"><label style="font-size:10px;color:var(--text3)">Desde</label><input type="date" class="fc" id="bnc-mov-des" style="padding:6px 8px;font-size:11px"></div>
      <div class="fg" style="margin:0"><label style="font-size:10px;color:var(--text3)">Hasta</label><input type="date" class="fc" id="bnc-mov-hta" style="padding:6px 8px;font-size:11px"></div>
      <div class="fg" style="margin:0"><label style="font-size:10px;color:var(--text3)">Tipo</label><select class="fc" id="bnc-mov-tipo" style="padding:6px 8px;font-size:11px"><option value="">Todos</option><option value="credito">Entradas</option><option value="debito">Salidas</option></select></div>
      <button class="btn btn-g btn-sm" onclick="renderMovBNC()">Filtrar</button>
      <button class="btn btn-p btn-sm" onclick="registrarMovManual()">+ Registrar</button>
    </div>
    <div class="g4" style="margin-bottom:10px">
      <div class="card card-sm"><div style="font-size:9px;color:var(--text3)">ENTRADAS</div><div style="font-family:var(--m);font-size:16px;font-weight:700;color:var(--green)" id="bnc-tot-entr">Bs 0</div></div>
      <div class="card card-sm"><div style="font-size:9px;color:var(--text3)">SALIDAS</div><div style="font-family:var(--m);font-size:16px;font-weight:700;color:var(--red)" id="bnc-tot-sal">Bs 0</div></div>
      <div class="card card-sm"><div style="font-size:9px;color:var(--text3)">BALANCE</div><div style="font-family:var(--m);font-size:16px;font-weight:700;color:var(--blue)" id="bnc-tot-bal">Bs 0</div></div>
      <div class="card card-sm"><div style="font-size:9px;color:var(--text3)">TRANSACCIONES</div><div style="font-family:var(--m);font-size:16px;font-weight:700;color:var(--teal)" id="bnc-tot-num">0</div></div>
    </div>
    <div class="tw"><table><thead><tr><th>Fecha</th><th>Tipo</th><th>Descripcion</th><th>Referencia</th><th>Monto Bs</th><th>USD equiv</th><th>Conciliado</th><th></th></tr></thead><tbody id="tb-bnc-mov"></tbody></table></div>
  </div>
  <div id="tab-bnc-conc" style="display:none">
    <div class="g2" style="margin-bottom:12px">
      <div class="card"><div class="st" style="margin-bottom:8px">Estado Conciliacion</div><div id="conc-estado"></div></div>
      <div class="card"><div class="st" style="margin-bottom:8px">Sin Conciliar</div><div id="conc-pend"></div></div>
    </div>
    <div class="tw"><table><thead><tr><th>Fecha BNC</th><th>Monto Bs</th><th>USD</th><th>Referencia</th><th>Factura</th><th>Estado</th><th></th></tr></thead><tbody id="tb-conc"></tbody></table></div>
  </div>
  <div id="tab-bnc-pend" style="display:none">
    <div class="alert-w">Los pagos montados quedan PENDIENTES en BNCNET. El firmante autorizado debe aprobarlos. La app NUNCA firma por ti.</div>
    <div id="bnc-pend-lista"><div style="text-align:center;color:var(--text3);padding:30px">Sin pagos pendientes de autorizar</div></div>
  </div>
  <div id="tab-bnc-cfg" style="display:none">
    <div class="g2">
      <div class="card">
        <div class="st" style="margin-bottom:12px">🏦 Credenciales API BNC</div>
        <div class="alert-w" style="margin-bottom:10px">CONFIDENCIAL. Solo admin. Credenciales otorgadas por el BNC como persona juridica.</div>
        <div class="fg"><label>BNC Client GUID</label><input class="fc" id="bnc-guid" type="password" placeholder="Tu GUID de cliente BNC" style="font-family:var(--m)"></div>
        <div class="fg"><label>BNC Master Key</label><input class="fc" id="bnc-mkey" type="password" placeholder="Tu clave maestra BNC" style="font-family:var(--m)"></div>
        <div class="fg"><label>Numero de Cuenta BNC</label><input class="fc" id="bnc-cuenta" placeholder="0000-0000-00-0000000000" style="font-family:var(--m)"></div>
        <div class="fg"><label>RIF</label><input class="fc" id="bnc-rif" value="J-29566107-0"></div>
        <div class="fg"><label>Ambiente</label><select class="fc" id="bnc-amb"><option value="production">Produccion</option><option value="development">Pruebas</option></select></div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-g" style="flex:1" onclick="guardarConfigBNC()">Guardar</button>
          <button class="btn btn-b" style="flex:1" onclick="testBNC()">🔌 Probar</button>
        </div>
        <div id="bnc-test-res" style="margin-top:8px;font-size:12px;display:none"></div>
      </div>
      <div class="card">
        <div class="st" style="margin-bottom:10px">Funcionalidades BNC</div>
        <div style="font-size:12px;color:var(--text2);line-height:2">
          ✅ Consulta saldo en tiempo real<br>✅ Historial de transferencias<br>✅ Conciliacion automatica de cobros<br>✅ Monta nomina (operador) → firma en BNCNET<br>✅ Monta pagos proveedores → firma en BNCNET<br>✅ Valida cuentas P2P antes de pagar<br>✅ Comprobantes automaticos<br>✅ WhatsApp al firmante cuando hay pagos<br><br>
          <b style="color:var(--yellow)">Como obtener credenciales:</b><br>
          Ve al BNC como persona juridica y solicita la API de Pagos Electronicos
        </div>
      </div>
    </div>
  </div>
</div>

<div id="p-proveedores" class="page">
  <div class="switch-row">
    <div class="sw on" id="sw-prov-cxp" onclick="switchProvTab('cxp')">Cuentas por Pagar</div>
    <div class="sw" id="sw-prov-lista" onclick="switchProvTab('lista')">Proveedores</div>
    <div class="sw" id="sw-prov-ret" onclick="switchProvTab('ret')">Retenciones IVA</div>
    <div class="sw" id="sw-prov-hist" onclick="switchProvTab('hist')">Historial</div>
  </div>
  <div id="tab-prov-cxp">
    <div class="g2" style="margin-bottom:10px">
      <div class="card">
        <div class="st" style="margin-bottom:12px">📦 Nueva Nota de Entrega</div>
        <div class="fr2">
          <div class="fg"><label>Proveedor</label><select class="fc" id="cxp-prov" onchange="autoLlenarProv()"><option value="">-- Seleccionar --</option></select></div>
          <div class="fg"><label>Fecha</label><input type="date" class="fc" id="cxp-fecha"></div>
        </div>
        <div class="fr2">
          <div class="fg"><label>N. Nota de Entrega</label><input class="fc" id="cxp-nota" placeholder="NE-001" style="font-family:var(--m)"></div>
          <div class="fg"><label>N. Factura (si tiene)</label><input class="fc" id="cxp-factura" placeholder="F-001"></div>
        </div>
        <div class="fg"><label>Que entregaron</label><input class="fc" id="cxp-desc" placeholder="Ej: Cambio de aceite y filtros JAC-B001..."></div>
        <div class="fr3">
          <div class="fg"><label>Monto USD (sin IVA)</label><input type="number" class="fc" id="cxp-monto" placeholder="0.00" oninput="calcCXP()" style="font-family:var(--m)"></div>
          <div class="fg"><label>IVA</label><select class="fc" id="cxp-iva" onchange="calcCXP()"><option value="0">Sin IVA</option><option value="16" selected>16%</option><option value="8">8%</option></select></div>
          <div class="fg"><label>Tasa de pago</label><select class="fc" id="cxp-tasa" onchange="calcCXP()"><option value="bcvDolar">BCV Dolar</option><option value="bcvEuro">BCV Euro</option><option value="binance">Binance</option><option value="promedio">Promedio</option></select></div>
        </div>
        <div id="cxp-calculo" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:10px;display:none;font-size:11px">
          <div style="font-weight:700;color:var(--green);margin-bottom:6px">Calculo automatico:</div>
          <div class="fr2"><div>Base USD: <b id="cxp-c-base" style="font-family:var(--m)">$0</b></div><div>IVA: <b id="cxp-c-iva" style="font-family:var(--m)">$0</b></div></div>
          <div class="fr2" style="margin-top:5px"><div>Total USD: <b id="cxp-c-tot" style="font-family:var(--m);color:var(--green)">$0</b></div><div>Tasa: <b id="cxp-c-tasa" style="font-family:var(--m)">--</b></div></div>
          <div class="fr2" style="margin-top:5px"><div>Total Bs: <b id="cxp-c-bs" style="font-family:var(--m);color:var(--yellow)">Bs 0</b></div><div id="cxp-c-ret-w" style="display:none">Retencion: <b id="cxp-c-ret" style="font-family:var(--m);color:var(--red)">$0</b></div></div>
          <div id="cxp-c-neto-w" style="margin-top:6px;border-top:1px solid var(--border);padding-top:6px;display:none">A TRANSFERIR: <b id="cxp-c-neto" style="font-family:var(--m);font-size:13px;color:var(--green)">$0</b></div>
        </div>
        <div class="fg"><label>Plazo de pago</label><select class="fc" id="cxp-plazo"><option value="0">Inmediato</option><option value="15">15 dias</option><option value="30" selected>30 dias</option><option value="45">45 dias</option><option value="60">60 dias</option></select></div>
        <button class="btn btn-g" style="width:100%" onclick="guardarCXP()">✔ Registrar Cuenta por Pagar</button>
      </div>
      <div>
        <div class="g2" style="margin-bottom:8px">
          <div class="stat r"><div class="stat-lbl">Por Pagar</div><div class="stat-val" style="font-size:16px;color:var(--red)" id="cxp-stat-pend">$0</div><div class="stat-sub" id="cxp-cnt-pend">0 facturas</div></div>
          <div class="stat y"><div class="stat-lbl">Vencidas</div><div class="stat-val" style="font-size:16px;color:var(--yellow)" id="cxp-stat-venc">$0</div><div class="stat-sub" id="cxp-cnt-venc">0 facturas</div></div>
        </div>
        <div class="card"><div class="st" style="margin-bottom:8px">Proximas a Vencer</div><div id="cxp-proximas" style="font-size:12px;color:var(--text3)">Sin facturas pendientes</div></div>
      </div>
    </div>
    <div class="tw"><table><thead><tr><th>Fecha</th><th>Proveedor</th><th>Nota</th><th>Descripcion</th><th>Base $</th><th>IVA</th><th>Total $</th><th>Ret $</th><th>A Pagar $</th><th>En Bs hoy</th><th>Vence</th><th>Estado</th><th></th></tr></thead><tbody id="tb-cxp"></tbody></table></div>
  </div>
  <div id="tab-prov-lista" style="display:none">
    <div class="g2">
      <div class="card">
        <div class="st" style="margin-bottom:12px">Nuevo Proveedor</div>
        <div class="fr2">
          <div class="fg"><label>Nombre / Razon Social</label><input class="fc" id="pv-nombre" placeholder="Empresa SA"></div>
          <div class="fg"><label>RIF <button class="btn btn-s btn-xs" onclick="abrirSENIAT()" style="margin-left:4px">SENIAT↗</button></label><input class="fc" id="pv-rif" placeholder="J-00000000-0"></div>
        </div>
        <div class="fr2">
          <div class="fg"><label>Banco</label><select class="fc" id="pv-banco"><option>BNC</option><option>Banesco</option><option>Banco de Venezuela</option><option>Mercantil</option><option>Provincial</option><option>BOD</option><option>Otro</option></select></div>
          <div class="fg"><label>Tipo Cuenta</label><select class="fc" id="pv-tcuenta"><option>Corriente</option><option>Ahorro</option></select></div>
        </div>
        <div class="fr2">
          <div class="fg"><label>N. Cuenta</label><input class="fc" id="pv-ncuenta" style="font-family:var(--m)" placeholder="0000-0000-00-0000000000"></div>
          <div class="fg"><label>Telefono / Pago Movil</label><input class="fc" id="pv-tel" placeholder="+58 414-000-0000"></div>
        </div>
        <div class="fr2">
          <div class="fg"><label>Con que tasa se paga</label><select class="fc" id="pv-tasa"><option value="bcvDolar">BCV Dolar</option><option value="bcvEuro">BCV Euro</option><option value="binance">Binance</option><option value="promedio">Promedio</option></select></div>
          <div class="fg"><label>Categoria</label><select class="fc" id="pv-cat"><option>Mantenimiento</option><option>Combustible</option><option>Seguros</option><option>Servicios</option><option>Alquiler</option><option>Administrativo</option><option>Otro</option></select></div>
        </div>
        <div style="border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:10px">
          <div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:8px">RETENCIONES SENIAT</div>
          <div class="fr2">
            <div class="fg" style="margin-bottom:0"><label>Contribuyente Especial</label><select class="fc" id="pv-contrib" onchange="toggleRetIVA(this.value)"><option value="no">No</option><option value="si">Si</option></select></div>
            <div class="fg" id="pv-ret-w" style="margin-bottom:0;display:none"><label>% Retencion IVA</label><select class="fc" id="pv-ret-pct"><option value="75">75% (estandar)</option><option value="100">100%</option><option value="50">50%</option></select></div>
          </div>
          <div class="fg" id="pv-islr-w" style="margin-top:8px;margin-bottom:0;display:none"><label>% Retencion ISLR</label><input type="number" class="fc" id="pv-islr-pct" placeholder="0" min="0" max="10" step="0.5"></div>
        </div>
        <input type="hidden" id="pv-edit-id">
        <button class="btn btn-g" style="width:100%" onclick="guardarProveedor()">Guardar Proveedor</button>
      </div>
      <div class="card"><div class="st" style="margin-bottom:10px">Proveedores Registrados</div><div id="pv-lista-render"></div></div>
    </div>
  </div>
  <div id="tab-prov-ret" style="display:none">
    <div class="g2" style="margin-bottom:12px">
      <div class="card"><div class="st" style="margin-bottom:8px">Resumen Retenciones</div><div id="ret-resumen"></div></div>
      <div class="card">
        <div class="st" style="margin-bottom:8px">Calcular Manual</div>
        <div class="fg"><label>Proveedor</label><select class="fc" id="ret-prov"><option value="">-- Seleccionar --</option></select></div>
        <div class="fr2">
          <div class="fg"><label>Base imponible $</label><input type="number" class="fc" id="ret-base" oninput="calcRet()" placeholder="0.00" style="font-family:var(--m)"></div>
          <div class="fg"><label>Tasa BCV $</label><input type="number" class="fc" id="ret-tasa" oninput="calcRet()" placeholder="487.12" style="font-family:var(--m)"></div>
        </div>
        <div id="ret-calc" style="background:var(--bg3);border-radius:8px;padding:10px;font-size:11px;display:none">
          <div class="fr2"><div>IVA 16%: <b id="rc-iva" style="font-family:var(--m)">$0</b></div><div>Retencion: <b id="rc-ret" style="font-family:var(--m);color:var(--red)">$0</b></div></div>
          <div class="fr2" style="margin-top:5px"><div>A Transferir: <b id="rc-neto" style="font-family:var(--m);color:var(--green)">$0</b></div><div>Ret Bs: <b id="rc-ret-bs" style="font-family:var(--m);color:var(--yellow)">Bs 0</b></div></div>
        </div>
      </div>
    </div>
    <div class="tw"><table><thead><tr><th>Fecha</th><th>Proveedor</th><th>Factura</th><th>Base $</th><th>IVA $</th><th>% Ret</th><th>Ret $</th><th>Ret Bs</th><th>Estado</th></tr></thead><tbody id="tb-ret"></tbody></table></div>
  </div>
  <div id="tab-prov-hist" style="display:none">
    <div class="g3" style="margin-bottom:10px">
      <div class="stat t"><div class="stat-lbl">Total Pagado</div><div class="stat-val" style="font-size:16px;color:var(--teal)" id="hist-pv-tot">$0</div></div>
      <div class="stat"><div class="stat-lbl">Este Mes</div><div class="stat-val" style="font-size:16px" id="hist-pv-mes">$0</div></div>
      <div class="stat b"><div class="stat-lbl">Retenciones</div><div class="stat-val" style="font-size:16px;color:var(--blue)" id="hist-pv-ret">$0</div></div>
    </div>
    <div class="tw"><table><thead><tr><th>F.Pago</th><th>Proveedor</th><th>Nota</th><th>Factura</th><th>Base $</th><th>Total $</th><th>Ret $</th><th>Pagado $</th><th>Pagado Bs</th><th>Tasa</th><th>Ref BNC</th></tr></thead><tbody id="tb-pv-hist"></tbody></table></div>
  </div>
</div>

<div id="p-documentos" class="page">
  <div class="switch-row">
    <div class="sw on" id="sw-doc-alertas" onclick="switchDocTab('alertas')">⚠️ Alertas</div>
    <div class="sw" id="sw-doc-cams" onclick="switchDocTab('cams')">🚛 Camiones</div>
    <div class="sw" id="sw-doc-emps" onclick="switchDocTab('emps')">👤 Choferes</div>
  </div>
  <div id="tab-doc-alertas">
    <div class="g2">
      <div class="card"><div class="st" style="margin-bottom:8px">🔴 Vencidos / Urgentes</div><div id="doc-vencidos"><div style="color:var(--green);font-size:12px;padding:10px">✓ Todo en regla</div></div></div>
      <div class="card"><div class="st" style="margin-bottom:8px">🟡 Proximos a Vencer (30 dias)</div><div id="doc-proximos"><div style="color:var(--teal);font-size:12px;padding:10px">Sin vencimientos proximos</div></div></div>
    </div>
  </div>
  <div id="tab-doc-cams" style="display:none">
    <div class="card" style="margin-bottom:10px">
      <div class="st" style="margin-bottom:10px">Actualizar Documento de Camion</div>
      <div class="fr3">
        <div class="fg"><label>Camion</label><select class="fc" id="doc-cam-sel"><option value="">-- Seleccionar --</option></select></div>
        <div class="fg"><label>Documento</label><select class="fc" id="doc-cam-tipo"><option value="seguro">Seguro del Camion</option><option value="circulacion">Carnet de Circulacion</option><option value="revision">Revision Tecnica INTT</option></select></div>
        <div class="fg"><label>Fecha de Vencimiento</label><input type="date" class="fc" id="doc-cam-venc"></div>
      </div>
      <div class="fr2">
        <div class="fg"><label>N. Poliza o Documento</label><input class="fc" id="doc-cam-num" placeholder="Numero de poliza..."></div>
        <div class="fg"><label>Aseguradora / Ente</label><input class="fc" id="doc-cam-ente" placeholder="Seguros Caracas, INTT..."></div>
      </div>
      <button class="btn btn-g btn-sm" onclick="guardarDocCam()">Guardar</button>
    </div>
    <div id="doc-cam-tabla"></div>
  </div>
  <div id="tab-doc-emps" style="display:none">
    <div class="card" style="margin-bottom:10px">
      <div class="st" style="margin-bottom:10px">Actualizar Documento de Empleado</div>
      <div class="fr3">
        <div class="fg"><label>Empleado</label><select class="fc" id="doc-emp-sel"><option value="">-- Seleccionar --</option></select></div>
        <div class="fg"><label>Documento</label><select class="fc" id="doc-emp-tipo"><option value="cedula">Cedula de Identidad</option><option value="licencia">Licencia de Conducir</option><option value="medico">Certificado Medico</option></select></div>
        <div class="fg"><label>Fecha de Vencimiento</label><input type="date" class="fc" id="doc-emp-venc"></div>
      </div>
      <div class="fr2">
        <div class="fg"><label>N. Documento</label><input class="fc" id="doc-emp-num" placeholder="V-12345678 / 0000000"></div>
        <div class="fg"><label>Grado Licencia</label><select class="fc" id="doc-emp-grado"><option value="">N/A</option><option value="3">3er Grado</option><option value="4">4to Grado</option><option value="5">5to Grado</option></select></div>
      </div>
      <button class="btn btn-g btn-sm" onclick="guardarDocEmp()">Guardar</button>
    </div>
    <div id="doc-emp-tabla"></div>
  </div>
</div>

<div id="p-asistencia" class="page">
  <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;align-items:flex-end">
    <div class="fg" style="margin:0"><label style="font-size:10px;color:var(--text3)">Semana</label><select class="fc" id="asis-sem" onchange="renderAsistencia()" style="padding:6px 8px;font-size:11px"><option>Semana 1</option><option>Semana 2</option><option>Semana 3</option><option>Semana 4</option><option>Semana 5</option></select></div>
    <div class="fg" style="margin:0"><label style="font-size:10px;color:var(--text3)">Mes</label><select class="fc" id="asis-mes" onchange="renderAsistencia()" style="padding:6px 8px;font-size:11px"><option value="abr-26">Abril 2026</option><option value="may-26">Mayo 2026</option><option value="mar-26">Marzo 2026</option></select></div>
    <button class="btn btn-g btn-sm" onclick="marcarTodosPresente()">✅ Todos Presente Hoy</button>
    <button class="btn btn-s btn-sm" onclick="exportarAsistencia()">Excel</button>
    <button class="btn btn-s btn-sm" onclick="imprimirAsistencia()">🖨 Imprimir</button>
  </div>
  <div class="g4" style="margin-bottom:10px">
    <div class="stat"><div class="stat-lbl">Empleados</div><div class="stat-val" id="asis-total">-</div></div>
    <div class="stat" style="border-top-color:var(--green)"><div class="stat-lbl">Presentes Hoy</div><div class="stat-val" style="color:var(--green)" id="asis-pres">-</div></div>
    <div class="stat r"><div class="stat-lbl">Ausentes Hoy</div><div class="stat-val" style="color:var(--red)" id="asis-aus">-</div></div>
    <div class="stat y"><div class="stat-lbl">% Asistencia</div><div class="stat-val" style="color:var(--yellow)" id="asis-pct">-</div></div>
  </div>
  <div class="card" style="margin-bottom:10px">
    <div class="sh"><div class="st">Control Semanal</div><div style="font-size:10px;color:var(--text3)">L M Mi J V S = Lun-Sab</div></div>
    <div id="asis-tabla" style="overflow-x:auto"></div>
  </div>
  <div class="card">
    <div class="st" style="margin-bottom:8px">ℹ️ Integracion ZKTeco</div>
    <div style="font-size:12px;color:var(--text2);line-height:1.8">✅ Asistencia manual disponible · 🔧 ZKTeco WiFi (ZK400/F22) → red local Starlink · 📡 Sincronizacion cada 5 min</div>
    <div style="margin-top:8px;display:flex;gap:8px">
      <div class="fg" style="flex:1;margin:0"><label style="font-size:10px;color:var(--text3)">IP del lector ZKTeco</label><input class="fc" id="zkteco-ip" placeholder="192.168.1.100" style="font-family:var(--m)"></div>
      <div style="display:flex;align-items:flex-end;padding-bottom:0"><button class="btn btn-b btn-sm" onclick="testZKTeco()">🔌 Probar</button></div>
    </div>
  </div>
</div>

<div id="p-prestamos" class="page">
  <div class="g2" style="margin-bottom:10px">
    <div class="card">
      <div class="st" style="margin-bottom:12px">💳 Nuevo Prestamo</div>
      <div class="fr2">
        <div class="fg"><label>Empleado</label><select class="fc" id="prest-emp"><option value="">-- Seleccionar --</option></select></div>
        <div class="fg"><label>Fecha</label><input type="date" class="fc" id="prest-fecha"></div>
      </div>
      <div class="fr2">
        <div class="fg"><label>Monto en USD $</label><input type="number" class="fc" id="prest-monto" placeholder="0.00" oninput="calcPrest()" style="font-family:var(--m)"></div>
        <div class="fg"><label>Semanas para pagar</label><input type="number" class="fc" id="prest-sems" placeholder="4" min="1" max="52" oninput="calcPrest()"></div>
      </div>
      <div class="fg"><label>Motivo</label><input class="fc" id="prest-motivo" placeholder="Descripcion breve..."></div>
      <div id="prest-calc" style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:10px;display:none;font-size:11px">
        <div style="color:var(--green);font-weight:700;margin-bottom:6px">Plan de pago:</div>
        <div class="fr3">
          <div>Total: <b id="pc-total" style="font-family:var(--m);color:var(--green)">$0</b></div>
          <div>Por semana: <b id="pc-cuota" style="font-family:var(--m);color:var(--yellow)">$0</b></div>
          <div>Semanas: <b id="pc-sems" style="font-family:var(--m);color:var(--teal)">0</b></div>
        </div>
        <div style="font-size:9px;color:var(--text3);margin-top:5px">Se descuenta automaticamente de la nomina. Siempre en Bs a tasa BCV del dia de pago.</div>
      </div>
      <button class="btn btn-g" style="width:100%" onclick="guardarPrestamo()">Registrar Prestamo</button>
    </div>
    <div>
      <div class="g2" style="margin-bottom:8px">
        <div class="stat y"><div class="stat-lbl">Activos</div><div class="stat-val" style="color:var(--yellow)" id="prest-activos">0</div></div>
        <div class="stat r"><div class="stat-lbl">Por Cobrar</div><div class="stat-val" style="font-size:15px;color:var(--red)" id="prest-total-pend">$0</div></div>
      </div>
      <div class="card"><div class="st" style="margin-bottom:8px">Proximos descuentos en nomina</div><div id="prest-prox" style="font-size:12px;color:var(--text3)">Sin prestamos activos</div></div>
    </div>
  </div>
  <div class="tw"><table><thead><tr><th>Empleado</th><th>Fecha</th><th>Total $</th><th>Semanas</th><th>$/Sem</th><th>Pagado $</th><th>Restante $</th><th>Cuotas OK</th><th>Estado</th><th></th></tr></thead><tbody id="tb-prest"></tbody></table></div>
</div>

<div id="p-multas" class="page">
  <div class="g2" style="margin-bottom:10px">
    <div class="card">
      <div class="st" style="margin-bottom:12px">⚖️ Registrar Multa</div>
      <div class="fr2">
        <div class="fg"><label>Camion</label><select class="fc" id="mul-cam"><option value="">-- Seleccionar --</option></select></div>
        <div class="fg"><label>Fecha</label><input type="date" class="fc" id="mul-fecha"></div>
      </div>
      <div class="fg"><label>Que paso</label><input class="fc" id="mul-desc" placeholder="Ej: Choque leve en semaforo, exceso de velocidad...">
